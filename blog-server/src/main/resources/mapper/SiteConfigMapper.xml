<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.blog.infrastructure.persistence.mapper.SiteConfigMapper">

    <resultMap id="BaseResultMap" type="com.blog.domain.entity.SiteConfig">
        <id column="id" property="id"/>
        <result column="config_key" property="configKey"/>
        <result column="config_value" property="configValue"/>
        <result column="description" property="description"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectByKey" resultMap="BaseResultMap">
        SELECT * FROM site_config WHERE config_key = #{configKey}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM site_config
    </select>

    <update id="updateByKey">
        UPDATE site_config SET config_value = #{configValue} WHERE config_key = #{configKey}
    </update>
</mapper>
