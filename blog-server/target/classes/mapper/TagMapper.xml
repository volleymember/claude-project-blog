<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.blog.infrastructure.persistence.mapper.TagMapper">

    <resultMap id="BaseResultMap" type="com.blog.domain.entity.Tag">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="slug" property="slug"/>
        <result column="color" property="color"/>
        <result column="create_time" property="createTime"/>
        <result column="article_count" property="articleCount"/>
    </resultMap>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM tag WHERE id = #{id}
    </select>

    <select id="selectByName" resultMap="BaseResultMap">
        SELECT * FROM tag WHERE name = #{name}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT t.*, (SELECT COUNT(*) FROM article_tag WHERE tag_id = t.id) as article_count
        FROM tag t
        ORDER BY t.id DESC
    </select>

    <select id="selectByArticleId" resultMap="BaseResultMap">
        SELECT t.* FROM tag t
        INNER JOIN article_tag at ON t.id = at.tag_id
        WHERE at.article_id = #{articleId}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tag (name, slug, color)
        VALUES (#{name}, #{slug}, #{color})
    </insert>

    <update id="update">
        UPDATE tag
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="slug != null">slug = #{slug},</if>
            <if test="color != null">color = #{color},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM tag WHERE id = #{id}
    </delete>
</mapper>
